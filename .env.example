# =====================================================================
# KT Chauffeur Privé — variables d'environnement
# Copier en .env.local et remplir les vraies valeurs.
# =====================================================================

# ---------- Mapbox ----------
# https://account.mapbox.com/access-tokens/
# Public token (commence par pk.) — exposé côté navigateur (autocomplete)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# Token serveur (peut être le même pk., ou un secret sk. avec scopes restreints)
# Utilisé par /api/distance pour appeler Directions API
MAPBOX_SECRET_TOKEN=pk.eyJ1...

# ---------- Stripe ----------
# https://dashboard.stripe.com/test/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret (créé via stripe listen ou dashboard)
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---------- Site ----------
NEXT_PUBLIC_SITE_URL=https://tka-driver.fr

# ---------- Email (Resend) ----------
# https://resend.com/api-keys
RESEND_API_KEY=re_xxx
# Email "from" — doit être un domaine vérifié sur Resend
EMAIL_FROM=reservations@tka-driver.fr
# Email où Tidiane reçoit les notifications de réservation
NOTIFICATION_EMAIL=tidiane@example.com

# ---------- Cal.com (optionnel) ----------
# Username Cal.com pour embed (laisser vide pour désactiver)
NEXT_PUBLIC_CAL_USERNAME=
